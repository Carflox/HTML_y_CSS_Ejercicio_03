<!DOCTYPE html>
<html>
  <head>
    <title>Aprendiendo a utilizar multimedia</title>
  </head>
  <body>
    <section>
      <h1>Aprendiendo a utilizar imágenes</h1>
      <img
        src="src/freefire-1234_9kd4.1200.jpg"
        alt="Imagen de mi videojuego favorito"
      />
    </section>
    <section>
      <h1>Aprendiendo a utilizar los vídeos</h1>
      <video
        src="src/Katy Perry - Firework (Official Music Video).mp4"
        controls
        autoplay
        loop
        muted
      ></video>
    </section>
    <section>
      <h1>Aprendiendo a utilizar los audios</h1>
      <audio
        src="src/Katy Perry - Firework (Official Music Video).mp3"
        controls
        autoplay
        loop
      ></audio>
    </section>
  </body>
</html>
